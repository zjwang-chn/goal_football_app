# 在 .github/workflows/cleanup.yml 中创建
name: 自动清理旧的工作流记录

on:
  schedule:
    - cron: '0 0 1 * *'  # 每月1号凌晨执行
  workflow_dispatch:      # 也支持手动触发

jobs:
  del_runs:
    runs-on: ubuntu-latest
    permissions:
      actions: write
      contents: read
    steps:
      - name: 删除旧的工作流运行
        uses: Mattraks/delete-workflow-runs@v2
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          repository: ${{ github.repository }}
          retain_days: 30        # 保留最近30天的记录
          keep_minimum_runs: 6   # 每个工作流至少保留6条记录
